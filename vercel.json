{
  "version": 2,
  "routes": [
    { "src": "/api/(.*)", "dest": "/server.js", "methods": ["GET", "POST", "PUT", "DELETE", "PATCH"] },
    { "src": "/public/(.*)", "status": 200 },
    { "src": "/(.*)", "dest": "/server.js" }
  ],
  "functions": {
    "server.js": {
      "memory": 1024,
      "maxDuration": 120,
      "includeFiles": "backend/**"
    }
  },
  "buildCommand": "yarn install || npm install",
  "outputDirectory": "."
}
