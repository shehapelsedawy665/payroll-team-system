# Database Configuration
MONGODB_URI=mongodb+srv://payroll_user:password@cluster.mongodb.net/payroll-db?retryWrites=true&w=majority

# Authentication - Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your-super-secret-jwt-key-min-32-characters-long-change-for-production
JWT_REFRESH_SECRET=your-refresh-secret-key-min-32-characters-long-change-for-production

# API Keys
BIOMETRIC_API_KEY=your-biometric-api-key-here-min-32-chars

# Security
ALLOWED_ORIGINS=https://payroll.your-domain.com,https://app.your-domain.com,http://localhost:3000

# Email Configuration (Gmail with app password or SendGrid)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-gmail-app-password

# Environment
NODE_ENV=production
PORT=3000

# Optional: For SendGrid email (production recommended)
# SMTP_HOST=smtp.sendgrid.net
# SMTP_PORT=587
# SMTP_USER=apikey
# SMTP_PASSWORD=SG.xxxxxxxxxxxxxxxxxxxxx